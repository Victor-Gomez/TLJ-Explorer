    <DrawingImage x:Key="ImageTypeIcon">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="Transparent">
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource TypeIconStroke}"
                            Thickness="2"
                            StartLineCap="Round"
                            EndLineCap="Round"
                            LineJoin="Round"/>
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <GeometryGroup>
                        <RectangleGeometry Rect="3,3,18,18"
                                RadiusX="2"
                                RadiusY="2"/>
                        <EllipseGeometry Center="9,9"
                                RadiusX="2"
                                RadiusY="2"/>
                        <PathGeometry Figures="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                    </GeometryGroup>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingImage.Drawing>
    </DrawingImage>

