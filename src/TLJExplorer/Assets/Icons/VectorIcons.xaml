<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Vector replacements for four of the per-type tree icons (image/sound/video/3D-model), converted
        from Lucide SVG icons (stroke="currentColor", fill="none", 24x24 viewBox) copied into this folder.
        WPF's path mini-language is compatible with SVG path "d" syntax, so each <path> was copied over
        largely verbatim; <rect>/<circle> became RectangleGeometry/EllipseGeometry. The app is dark-theme
        only (see App.xaml's ThemeMode="Dark"), so the stroke is hardcoded white rather than following
        currentColor; there is no light-mode variant to account for.
    -->
    <SolidColorBrush x:Key="TypeIconStroke"
            Color="White"/>

