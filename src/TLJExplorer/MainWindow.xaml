<Window x:Class="TLJExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TLJExplorer"
        xmlns:vm="clr-namespace:TLJExplorer.ViewModels"
        xmlns:views="clr-namespace:TLJExplorer.Views"
        mc:Ignorable="d"
        Title="TLJ Explorer" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/TLJExplorer.ico">


    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <HierarchicalDataTemplate DataType="{x:Type vm:FsNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Top"/>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Border Visibility="{Binding HasMod, Converter={StaticResource BoolToVisibility}}"
                                Margin="6,0,0,0" Padding="4,0" VerticalAlignment="Center"
                                CornerRadius="3"
                                Background="#40D084FF"
                                BorderBrush="#80D084FF" BorderThickness="1"
                                ToolTip="A mod file overrides this entry (see Options → Load Asset Mods).">
                            <TextBlock Text="MOD" FontSize="9" FontWeight="Bold"
                                       Foreground="#F0E4FF"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding SubtitleMatch}"
                               Visibility="{Binding HasSubtitleMatch, Converter={StaticResource BoolToVisibility}}"
                               FontSize="10.5" FontStyle="Italic" Opacity="0.75" TextTrimming="CharacterEllipsis"
                               MaxWidth="240"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Order matters: the TreeViewItem Style below references this ContextMenu via StaticResource,
             which resolves at parse time. If the ContextMenu isn't defined FIRST, the setter picks up
             DependencyProperty.UnsetValue and every right-click on a tree row throws. -->
        <ContextMenu x:Key="TreeItemContextMenu">
            <MenuItem Header="_Copy Path" Click="TreeContextCopyPath_Click"/>
            <MenuItem Header="_Reveal in Windows Explorer" Click="TreeContextRevealInExplorer_Click"
                      ToolTip="Only works for loose (non-archived) files."/>
            <Separator/>
            <MenuItem Header="Play _Localized Variant" Click="TreeContextPlayLocalized_Click"
                      ToolTip="If a sibling entry with the same name is marked localised, open and play it.">
                <MenuItem.Icon>
                    <Image Source="{StaticResource LanguagesIcon}" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="View _Original (bypass mod)" Click="TreeContextViewOriginal_Click"
                      ToolTip="Load this entry from the archive, ignoring any mod override.">
                <MenuItem.Icon>
                    <Image Source="{StaticResource EyeIcon}" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Compare Original vs _Mod..." Click="TreeContextCompareMod_Click"
                      ToolTip="Open the compare view with the original archive bytes on one side and the mod override on the other."/>
            <MenuItem Header="E_xtract as Mod" Click="TreeContextExtractAsMod_Click"
                      ToolTip="Copy this file's bytes into &lt;archiveDir&gt;/xarc/&lt;name&gt; so it becomes a modifiable override the game will pick up (ScummVM Stark's mod convention).">
                <MenuItem.Icon>
                    <Image Source="{StaticResource PlusIcon}" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="_Export This Item..." Click="TreeContextExportItem_Click"/>
            <MenuItem Header="_Batch Export This Folder..." Click="TreeContextBatchExport_Click"/>
        </ContextMenu>

        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="ContextMenu" Value="{StaticResource TreeItemContextMenu}"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Select TLJ Install Folder..." Click="SelectFolder_Click" InputGestureText="Ctrl+O"/>
                <MenuItem x:Name="RecentInstallsMenu" Header="Open _Recent" ItemsSource="{Binding}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}"/>
                            <EventSetter Event="Click" Handler="RecentInstallItem_Click"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="_Export..." Click="Export_Click" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Export _Raw..." Click="ExportRaw_Click"/>
                <MenuItem Header="_Batch Export Folder..." Click="BatchExport_Click"
                          ToolTip="Recursively export every recognised file under the selected folder into a chosen output directory (images→TGA, sounds→WAV, models→glTF binary)."/>
                <MenuItem Header="Export _Subtitles..." Click="ExportSubtitles_Click"
                          ToolTip="Extract every dialogue line reachable via the game's XRC data as a CSV manifest plus per-scene SRT subtitle files."/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem x:Name="AutoPlaySoundMenuItem" Header="_Auto-play Sound" IsCheckable="True" Click="AutoPlaySound_Click"/>
                <MenuItem x:Name="AutoPlayVideoMenuItem" Header="Auto-play _Video" IsCheckable="True" Click="AutoPlayVideo_Click"/>
                <MenuItem x:Name="LoopSoundMenuItem" Header="Loop _Sound Playback" IsCheckable="True" Click="LoopSound_Click"/>
                <MenuItem x:Name="ShowMipMapsMenuItem" Header="Show _Mip Maps" IsCheckable="True" Click="ShowMipMaps_Click"/>
                <MenuItem Header="Anti-_Alias">
                    <MenuItem x:Name="AntiAliasNoneMenuItem" Header="_None" IsCheckable="True" Tag="0" Click="AntiAlias_Click"/>
                    <MenuItem x:Name="AntiAlias2xMenuItem" Header="_2x" IsCheckable="True" Tag="2" Click="AntiAlias_Click"/>
                    <MenuItem x:Name="AntiAlias4xMenuItem" Header="_4x" IsCheckable="True" Tag="4" Click="AntiAlias_Click"/>
                    <MenuItem x:Name="AntiAliasDefaultMenuItem" Header="_Default" IsCheckable="True" Tag="-1" Click="AntiAlias_Click"/>
                </MenuItem>
                <MenuItem x:Name="HighQualityMenuItem" Header="_High Quality" IsCheckable="True" Click="HighQuality_Click"/>
                <Separator/>
                <MenuItem x:Name="DumpSceneDiagnosticsMenuItem" Header="_Dump Scene Diagnostics"
                          IsCheckable="True" Click="DumpSceneDiagnostics_Click"
                          ToolTip="When a scene folder is opened, write a per-scene table to %TEMP%\TLJExplorer_last_scene_items.txt for troubleshooting."/>
                <MenuItem x:Name="HideLocalizedMenuItem" Header="Hide _Localized Entries"
                          IsCheckable="True" Click="HideLocalized_Click"
                          ToolTip="Hide XARC entries flagged as localised (non-English). Only the English (flag=0) variants remain visible in the tree."/>
                <MenuItem x:Name="LoadAssetModsMenuItem" Header="Load Asset _Mods"
                          IsCheckable="True" Click="LoadAssetMods_Click"
                          ToolTip="Serve loose files under &lt;archive dir&gt;\xarc\ as overrides for the matching archive entries (ScummVM Stark's mod convention)."/>
                <MenuItem Header="Select External M_ods Folder..." Click="SelectExternalModsFolder_Click"
                          ToolTip="Point at a folder outside the install that mirrors the install's layout — files under &lt;modsDir&gt;/&lt;relPath&gt;/xarc/&lt;name&gt; will override the matching archive entries."/>
                <MenuItem x:Name="ClearExternalModsMenuItem" Header="Clear External Mods Folder" Click="ClearExternalModsFolder_Click"
                          IsEnabled="False"
                          ToolTip="Unlink the current external mods folder — reverts to only in-install mods."/>
                <MenuItem Header="Diagnose External Mods..." Click="DiagnoseExternalMods_Click"
                          ToolTip="Walk the current external mods folder and report which files did and did not resolve to VFS entries."/>
                <Separator/>
                <MenuItem Header="_Theme">
                    <MenuItem x:Name="ThemeSystemMenuItem" Header="_System" IsCheckable="True" Tag="System" Click="Theme_Click"/>
                    <MenuItem x:Name="ThemeLightMenuItem" Header="_Light" IsCheckable="True" Tag="Light" Click="Theme_Click"/>
                    <MenuItem x:Name="ThemeDarkMenuItem" Header="_Dark" IsCheckable="True" Tag="Dark" Click="Theme_Click"/>
                </MenuItem>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="SelectedPathText" Text="No file selected."/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="CancelBatchButton" Padding="6,2" Margin="0,0,8,0"
                            Visibility="Collapsed" Click="CancelBatchButton_Click"
                            ToolTip="Cancel the running batch operation.">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource CloseIcon}" Width="12" Height="12" Margin="0,0,4,0"/>
                            <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <ProgressBar x:Name="ScanProgressBar" Width="160" Height="16" IsIndeterminate="False" Visibility="Collapsed"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <ComboBox x:Name="TypeFilterCombo" Margin="0,0,0,4"
                              SelectionChanged="TreeFilter_Changed">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="16" Height="16" Margin="0,0,8,0"
                                           Source="{Binding IconResourceKey, Converter={StaticResource ResourceKeyToImageConverter}}"/>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- Search box with a leading magnifier glyph. The glyph is a plain overlay rather
                         than a real TextBox adorner because Fluent styling makes overriding the control
                         template noisy for something this small. -->
                    <Grid>
                        <TextBox x:Name="SearchBox" Padding="24,3,4,3"
                                 ToolTip="Search by file name or subtitle text (dialogue lines attached to sound entries in XRC)."
                                 TextChanged="SearchBox_TextChanged"/>
                        <Image Source="{StaticResource SearchIcon}" Width="14" Height="14"
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               Margin="6,0,0,0" IsHitTestVisible="False" Opacity="0.6"/>
                    </Grid>
                </StackPanel>

                <TreeView x:Name="Tree"
                          SelectedItemChanged="Tree_SelectedItemChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"/>

            <Grid Grid.Column="2" Margin="8">

                <!-- Image resources: XMG (single) and TM (possibly many named sub-images). -->
                <DockPanel x:Name="ImagePanel" Visibility="Collapsed">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <ComboBox x:Name="ImageSelector"
                                  SelectionChanged="ImageSelector_SelectionChanged"
                                  Visibility="Collapsed" HorizontalAlignment="Left" MinWidth="200"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="ImageCompareEnterButton" Padding="6,2" Margin="0,0,12,0"
                                    Visibility="Collapsed" Click="ImageCompareEnter_Click"
                                    ToolTip="Compare this image against its mod override.">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource SplitViewIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Compare Mod" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="ZoomLabel" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0" MinWidth="42"/>
                            <Button Content="Zoom Out" Padding="8,2" Margin="0,0,6,0" Click="ZoomOut_Click"/>
                            <Button Content="Zoom In" Padding="8,2" Margin="0,0,6,0" Click="ZoomIn_Click"/>
                            <Button Content="Reset Zoom" Padding="8,2" Click="ResetZoom_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                  PreviewMouseLeftButtonDown="ImageScrollViewer_MouseLeftButtonDown"
                                  PreviewMouseMove="ImageScrollViewer_MouseMove"
                                  PreviewMouseLeftButtonUp="ImageScrollViewer_MouseLeftButtonUp">
                        <Grid x:Name="ImageCenteringGrid"
                              MinWidth="{Binding ViewportWidth, ElementName=ImageScrollViewer}"
                              MinHeight="{Binding ViewportHeight, ElementName=ImageScrollViewer}">
                            <Image x:Name="PreviewImage" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.LayoutTransform>
                                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                </Image.LayoutTransform>
                            </Image>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>

                <!-- Compare original vs modded for image resources. Two mutually-exclusive views stacked
                     inside a single Grid content row so switching between them is a simple visibility
                     toggle. Both modes share zoom (wheel + buttons) and pan via ScrollViewers; the
                     side-by-side pair keeps its scroll offsets in sync so pixels stay aligned. -->
                <Grid x:Name="ImageComparePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <RadioButton x:Name="ImageCompareWipeMode" Content="Wipe" GroupName="ImageCompareMode" IsChecked="True"
                                             VerticalAlignment="Center" Margin="0,0,10,0" Checked="ImageCompareMode_Changed"/>
                                <RadioButton x:Name="ImageCompareSideBySideMode" Content="Side-by-side" GroupName="ImageCompareMode"
                                             VerticalAlignment="Center" Margin="0,0,14,0" Checked="ImageCompareMode_Changed"/>
                                <TextBlock x:Name="ImageCompareZoomLabel" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0" MinWidth="42"/>
                                <Button Content="Zoom Out" Padding="8,2" Margin="0,0,6,0" Click="ImageCompareZoomOut_Click"/>
                                <Button Content="Zoom In" Padding="8,2" Margin="0,0,6,0" Click="ImageCompareZoomIn_Click"/>
                                <Button Content="Reset Zoom" Padding="8,2" Margin="0,0,10,0" Click="ImageCompareZoomReset_Click"/>
                                <Button Content="Close" Padding="8,2" Click="ImageCompareClose_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="ImageCompareLabel" VerticalAlignment="Center" Opacity="0.8"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>

                    </Grid>

                    <!-- Content row: the two mode containers overlap at the same grid cell; visibility
                         alternates via ApplyImageCompareMode. -->
                    <Grid Grid.Row="1">

                        <!-- Wipe. The inner Grid uses MinWidth/MinHeight bound to the ScrollViewer's
                             viewport so the stage centres in the viewport when it's smaller and scrolls
                             when zoomed larger. -->
                        <ScrollViewer x:Name="ImageCompareWipeScroll"
                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      Cursor="Hand"
                                      PreviewMouseWheel="ImageCompare_PreviewMouseWheel"
                                      PreviewMouseLeftButtonDown="ImageComparePanScroll_MouseDown"
                                      PreviewMouseMove="ImageComparePanScroll_MouseMove"
                                      PreviewMouseLeftButtonUp="ImageComparePanScroll_MouseUp">
                            <Grid MinWidth="{Binding ViewportWidth, ElementName=ImageCompareWipeScroll}"
                                  MinHeight="{Binding ViewportHeight, ElementName=ImageCompareWipeScroll}">
                                <Grid x:Name="ImageCompareStage"
                                      HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.LayoutTransform>
                                        <ScaleTransform x:Name="ImageCompareStageScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.LayoutTransform>
                                    <!-- Both images stretched to the shared canvas size AND each clipped to
                                         its half of the divider. Clipping both (not just the mod) prevents
                                         transparent mod pixels from leaking a stretched low-res original
                                         through — the two never draw over the same pixel. -->
                                    <Image x:Name="ImageCompareOriginalImage" Stretch="Fill"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor">
                                        <Image.Clip>
                                            <RectangleGeometry x:Name="ImageCompareOriginalClip" Rect="0,0,0,0"/>
                                        </Image.Clip>
                                    </Image>
                                    <Image x:Name="ImageCompareModImage" Stretch="Fill"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor">
                                        <Image.Clip>
                                            <RectangleGeometry x:Name="ImageCompareClip" Rect="0,0,0,0"/>
                                        </Image.Clip>
                                    </Image>
                                    <!-- Visible thin divider bar (non-hit-testing, purely decorative). -->
                                    <Rectangle x:Name="ImageCompareDivider" Width="2" Fill="#FFE0A030"
                                               HorizontalAlignment="Left" IsHitTestVisible="False"/>
                                    <!-- Wider transparent hit-area for grabbing the divider — sits on top,
                                         so it wins over the ScrollViewer's pan handlers when clicked here.
                                         Cursor changes to horizontal-arrow to advertise it as draggable. -->
                                    <Rectangle x:Name="ImageCompareDividerHandle" Width="14" Fill="Transparent"
                                               HorizontalAlignment="Left" Cursor="SizeWE"
                                               MouseLeftButtonDown="ImageCompareDividerHandle_MouseDown"
                                               MouseMove="ImageCompareDividerHandle_MouseMove"
                                               MouseLeftButtonUp="ImageCompareDividerHandle_MouseUp"/>
                                    <TextBlock x:Name="ImageCompareOriginalTag" Text="ORIGINAL"
                                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,4,0,0"
                                               Foreground="White" FontSize="10" FontWeight="Bold"
                                               Background="#66000000" Padding="4,1" IsHitTestVisible="False"/>
                                    <TextBlock x:Name="ImageCompareModTag" Text="MODDED"
                                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                               Foreground="White" FontSize="10" FontWeight="Bold"
                                               Background="#66802040" Padding="4,1" IsHitTestVisible="False"/>
                                </Grid>
                            </Grid>
                        </ScrollViewer>

                        <!-- Side-by-side. Column 0 = ORIGINAL, Column 2 = MODDED. Each ScrollViewer uses
                             the same MinWidth-binding pattern so its content centres when small. -->
                        <Grid x:Name="ImageCompareSideBySideContainer" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <TextBlock Text="ORIGINAL" DockPanel.Dock="Top" HorizontalAlignment="Center"
                                           FontSize="10" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,4"/>
                                <ScrollViewer x:Name="ImageCompareSideOriginalScroll"
                                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                              Cursor="Hand"
                                              ScrollChanged="ImageCompareSideScroll_ScrollChanged"
                                              PreviewMouseWheel="ImageCompare_PreviewMouseWheel"
                                              PreviewMouseLeftButtonDown="ImageComparePanScroll_MouseDown"
                                              PreviewMouseMove="ImageComparePanScroll_MouseMove"
                                              PreviewMouseLeftButtonUp="ImageComparePanScroll_MouseUp">
                                    <Grid MinWidth="{Binding ViewportWidth, ElementName=ImageCompareSideOriginalScroll}"
                                          MinHeight="{Binding ViewportHeight, ElementName=ImageCompareSideOriginalScroll}">
                                        <Image x:Name="ImageCompareSideOriginal" Stretch="Fill"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor">
                                            <Image.LayoutTransform>
                                                <ScaleTransform x:Name="ImageCompareSideOriginalScale" ScaleX="1" ScaleY="1"/>
                                            </Image.LayoutTransform>
                                        </Image>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>

                            <Rectangle Grid.Column="1" Width="1" Fill="#40FFFFFF" Margin="8,0"/>

                            <DockPanel Grid.Column="2">
                                <TextBlock Text="MODDED" DockPanel.Dock="Top" HorizontalAlignment="Center"
                                           FontSize="10" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,4"
                                           Foreground="#FFF080B0"/>
                                <ScrollViewer x:Name="ImageCompareSideModScroll"
                                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                              Cursor="Hand"
                                              ScrollChanged="ImageCompareSideScroll_ScrollChanged"
                                              PreviewMouseWheel="ImageCompare_PreviewMouseWheel"
                                              PreviewMouseLeftButtonDown="ImageComparePanScroll_MouseDown"
                                              PreviewMouseMove="ImageComparePanScroll_MouseMove"
                                              PreviewMouseLeftButtonUp="ImageComparePanScroll_MouseUp">
                                    <Grid MinWidth="{Binding ViewportWidth, ElementName=ImageCompareSideModScroll}"
                                          MinHeight="{Binding ViewportHeight, ElementName=ImageCompareSideModScroll}">
                                        <Image x:Name="ImageCompareSideMod" Stretch="Fill"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor">
                                            <Image.LayoutTransform>
                                                <ScaleTransform x:Name="ImageCompareSideModScale" ScaleX="1" ScaleY="1"/>
                                            </Image.LayoutTransform>
                                        </Image>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- XRC scene folders: backdrop + static sprites blit into SceneBaseImage; Bink/Smacker
                     overlays are added as extra Image children on SceneCanvas at their (x,y), driven by
                     a shared DispatcherTimer that swaps each Image.Source per frame. -->
                <DockPanel x:Name="ScenePanel" Visibility="Collapsed">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock x:Name="SceneStatusText" VerticalAlignment="Center" Opacity="0.7"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <ToggleButton x:Name="SceneDiagnosticsToggle" Content="Diagnostics" Padding="8,2" Margin="0,0,10,0"
                                          Checked="SceneDiagnosticsToggle_Changed" Unchecked="SceneDiagnosticsToggle_Changed"
                                          ToolTip="Show a text panel of every Item/Anim in this scene, per XrcSceneModel.Diagnose."/>
                            <TextBlock x:Name="SceneZoomLabel" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0" MinWidth="42"/>
                            <Button Content="Zoom Out" Padding="8,2" Margin="0,0,6,0" Click="SceneZoomOut_Click"/>
                            <Button Content="Zoom In" Padding="8,2" Margin="0,0,6,0" Click="SceneZoomIn_Click"/>
                            <Button Content="Reset Zoom" Padding="8,2" Click="SceneResetZoom_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <TextBox x:Name="SceneDiagnosticsText" DockPanel.Dock="Right" Width="360"
                             Visibility="Collapsed" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                             Margin="8,0,0,0"/>
                    <ScrollViewer x:Name="SceneScrollViewer"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="SceneScrollViewer_PreviewMouseWheel">
                        <Grid MinWidth="{Binding ViewportWidth, ElementName=SceneScrollViewer}"
                              MinHeight="{Binding ViewportHeight, ElementName=SceneScrollViewer}">
                            <Canvas x:Name="SceneCanvas" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="Transparent">
                                <Canvas.LayoutTransform>
                                    <ScaleTransform x:Name="SceneScale" ScaleX="1" ScaleY="1"/>
                                </Canvas.LayoutTransform>
                                <Image x:Name="SceneBaseImage" Canvas.Left="0" Canvas.Top="0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>

                <!-- Text / hex-dump resources: BIFF, XRC, CIR, ANI (structural dumps), raw hex, errors.
                     The wrapping DockPanel adds a conditional "Back to Model" header row that appears
                     only when the user asked to see an .ani's source code from the model viewer, so
                     ordinary text dumps aren't cluttered by an irrelevant control. -->
                <DockPanel x:Name="TextViewer" Visibility="Collapsed">
                    <StackPanel x:Name="AniSourceHeader" DockPanel.Dock="Top" Orientation="Horizontal"
                                Visibility="Collapsed" Margin="0,0,0,8">
                        <Button Padding="6,2" Click="BackToModel_Click"
                                ToolTip="Return to the 3D model view.">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2190;" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Back to Model" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="AniSourceHeaderLabel" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.7"/>
                    </StackPanel>
                    <TextBox x:Name="TextPanel"
                             IsReadOnly="True" IsReadOnlyCaretVisible="True"
                             FontFamily="Consolas" FontSize="12"
                             TextWrapping="NoWrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>

                <!-- Sound resources: OVS (Ogg) and ISN family (WAV), with optional dialogue subtitle.
                     Layout mirrors a standard media-player card: bold subtitle at top, waveform strip,
                     seek slider, current/total time labels flanking the slider, then Play/Stop icon
                     buttons centered below. -->
                <StackPanel x:Name="SoundPanel" Visibility="Collapsed" VerticalAlignment="Top" Margin="0,24,0,0">
                    <TextBlock x:Name="SubtitleText" Visibility="Collapsed"
                               TextWrapping="Wrap" FontSize="15" LineHeight="20"
                               Margin="0,0,0,24"/>

                    <!-- Waveform. We re-render the vector drawing at the panel's actual width whenever
                         the window resizes (see WaveformImage_SizeChanged), so the strip stays at a
                         constant bar-density regardless of window size. Stretch="None" therefore —
                         the drawing already matches the container. -->
                    <Image x:Name="WaveformImage" Height="64" Stretch="None"
                           HorizontalAlignment="Stretch"
                           SizeChanged="WaveformImage_SizeChanged"/>

                    <Slider x:Name="SoundSlider" Margin="0,4,0,0" Minimum="0"
                            Thumb.DragStarted="SoundSlider_DragStarted"
                            Thumb.DragCompleted="SoundSlider_DragCompleted"/>

                    <Grid Margin="0,4,0,0">
                        <TextBlock x:Name="SoundCurrentTimeText" HorizontalAlignment="Left"
                                   FontFamily="Consolas" FontSize="12" Opacity="0.8"
                                   Text="0:00"/>
                        <TextBlock x:Name="SoundTotalTimeText" HorizontalAlignment="Right"
                                   FontFamily="Consolas" FontSize="12" Opacity="0.8"
                                   Text="0:00"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button x:Name="PlayPauseButton" Width="48" Height="48" Click="PlayPauseButton_Click"
                                ToolTip="Play / Pause (Space)">
                            <Image x:Name="PlayPauseIcon" Source="{StaticResource PlayIcon}" Width="22" Height="22"/>
                        </Button>
                        <Button x:Name="StopButton" Width="48" Height="48" Margin="12,0,0,0" Click="StopButton_Click"
                                ToolTip="Stop">
                            <Image Source="{StaticResource StopIcon}" Width="18" Height="18"/>
                        </Button>
                        <ToggleButton x:Name="SoundCompareToggle" Height="48" Padding="10,0" Margin="16,0,0,0"
                                      Visibility="Collapsed"
                                      Checked="SoundCompareToggle_Changed" Unchecked="SoundCompareToggle_Changed"
                                      ToolTip="A/B: play the mod override instead of the original.">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{StaticResource SwapIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                                <TextBlock Text="Play mod" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>

                <!-- Video resources: SSS (Smacker) and BBB (Bink). ffmpeg.exe transcodes the raw stream
                     to a temp MP4 (H.264+AAC) on load and WPF's MediaElement plays it natively.
                     "Open in External Player" is kept as a fallback. -->
                <DockPanel x:Name="VideoPanel" Visibility="Collapsed" Margin="0,24,0,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock x:Name="VideoLabel" TextWrapping="Wrap" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <TextBlock x:Name="VideoZoomLabel" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0" MinWidth="42"/>
                            <Slider x:Name="VideoZoomSlider" Width="180" VerticalAlignment="Center"
                                    Minimum="25" Maximum="800" Value="100"
                                    SmallChange="10" LargeChange="50"
                                    ValueChanged="VideoZoomSlider_ValueChanged"/>
                        </StackPanel>
                    </DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
                        <Button x:Name="VideoPlayPauseButton" Content="Pause" Width="80" Margin="0,0,6,0" Click="VideoPlayPauseButton_Click"/>
                        <CheckBox x:Name="RemoveBackgroundCheck" Content="Remove background" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Checked="RemoveBackground_Changed" Unchecked="RemoveBackground_Changed"/>
                        <Button x:Name="OpenExternalButton" Content="Open in External Player"
                                Padding="12,6" Click="OpenExternalButton_Click"/>
                    </StackPanel>
                    <ScrollViewer x:Name="VideoScrollViewer"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="VideoScrollViewer_PreviewMouseWheel">
                        <Grid MinWidth="{Binding ViewportWidth, ElementName=VideoScrollViewer}"
                              MinHeight="{Binding ViewportHeight, ElementName=VideoScrollViewer}">
                            <MediaElement x:Name="VideoPlayer" LoadedBehavior="Manual" UnloadedBehavior="Manual"
                                          Stretch="Uniform" ScrubbingEnabled="True"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          MediaEnded="VideoPlayer_MediaEnded" MediaFailed="VideoPlayer_MediaFailed">
                                <MediaElement.LayoutTransform>
                                    <ScaleTransform x:Name="VideoScale" ScaleX="1" ScaleY="1"/>
                                </MediaElement.LayoutTransform>
                            </MediaElement>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>

                <!-- 3D model resources: CIR, skeletally posed/skinned from an ANI animation's sampled
                     keyframes (see SkeletonPoser/ModelRenderer.ApplyPose). CIR itself stores no bind
                     pose, so with no animation selected the mesh shows unposed/identity-bone "rest" data,
                     which can look distorted (see ModelNoAnimationNote below). -->
                <Grid x:Name="ModelPanel" Visibility="Collapsed">
                    <views:GlModelViewerHost x:Name="ModelViewerHost"/>

                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="6" Width="380"
                                Background="#AA202020">
                        <TextBlock x:Name="ModelHintText" Margin="4,4,4,2" Opacity="0.6" FontSize="11" IsHitTestVisible="False"
                                   Text="Left-drag: orbit  |  Right-drag: pan  |  Wheel: zoom"/>

                        <CheckBox x:Name="ModelIncludeWholeInstallCheck" Content="Include whole install"
                                  Margin="4,2,4,4"
                                  Checked="ModelIncludeWholeInstall_Changed" Unchecked="ModelIncludeWholeInstall_Changed"/>

                        <Grid Margin="4,0,4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Model:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,4"/>
                            <ComboBox x:Name="ModelSelectorCombo" Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                      DisplayMemberPath="DisplayName" SelectionChanged="ModelSelectorCombo_SelectionChanged"/>

                            <TextBlock Text="Skin:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,4"/>
                            <ComboBox x:Name="SkinSelectorCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                                      DisplayMemberPath="DisplayName" SelectionChanged="SkinSelectorCombo_SelectionChanged"/>

                            <TextBlock Text="Animation:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="AnimationSelectorCombo" Grid.Row="2" Grid.Column="1"
                                      DisplayMemberPath="DisplayName" SelectionChanged="AnimationSelectorCombo_SelectionChanged"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                            <Button x:Name="ModelPlayPauseButton" Content="Play" Width="60" Margin="0,0,6,0" Click="ModelPlayPauseButton_Click"/>
                            <CheckBox x:Name="ModelLoopCheck" Content="Loop" IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0"
                                      Checked="ModelLoopCheck_Changed" Unchecked="ModelLoopCheck_Changed"/>
                            <TextBlock x:Name="ModelTimeText" VerticalAlignment="Center" Opacity="0.7" Text="0.0s / 0.0s"/>
                            <Button x:Name="ViewAniSourceButton" Padding="6,2" Margin="10,0,0,0"
                                    Visibility="Collapsed" Click="ViewAniSource_Click"
                                    ToolTip="View the currently-selected animation's decoded structure as text.">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource EyeIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Source" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Slider x:Name="ModelScrubSlider" Margin="4,0,4,4" Minimum="0" Maximum="1" ValueChanged="ModelScrubSlider_ValueChanged"
                                Thumb.DragStarted="ModelScrubSlider_DragStarted" Thumb.DragCompleted="ModelScrubSlider_DragCompleted"/>

                        <StackPanel Orientation="Horizontal" Margin="4,2,4,4">
                            <CheckBox x:Name="ModelWireframeCheck" VerticalAlignment="Center" Margin="0,0,10,0"
                                      Checked="ModelWireframe_Changed" Unchecked="ModelWireframe_Changed"
                                      ToolTip="Overlay a wireframe on the shaded mesh.">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource WireframeActionIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Wireframe" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <TextBlock Text="BG:" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0"/>
                            <ComboBox x:Name="ModelBackgroundCombo" Width="90" SelectionChanged="ModelBackground_Changed">
                                <ComboBoxItem Content="Dark" Tag="Dark"/>
                                <ComboBoxItem Content="Light" Tag="Light"/>
                                <ComboBoxItem Content="Transparent" Tag="Transparent"/>
                            </ComboBox>
                            <Button Padding="6,2" Margin="10,0,0,0" Click="ModelSavePng_Click"
                                    ToolTip="Save a PNG screenshot of the current view.">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource CameraActionIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Save PNG..." VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <ToggleButton x:Name="ModelCompareToggle" Padding="6,2" Margin="6,0,0,0"
                                          Visibility="Collapsed"
                                          Checked="ModelCompareToggle_Changed" Unchecked="ModelCompareToggle_Changed"
                                          ToolTip="Toggle between the original file and the modded override for this asset.">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource SwapIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Mod" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="4,2,4,6">
                            <TextBlock Text="View:" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,6,0"/>
                            <Button Content="Front" Padding="6,2" MinWidth="42" Margin="0,0,3,0" Tag="Front" Click="ModelOrthoView_Click"/>
                            <Button Content="Back"  Padding="6,2" MinWidth="42" Margin="0,0,3,0" Tag="Back"  Click="ModelOrthoView_Click"/>
                            <Button Content="Left"  Padding="6,2" MinWidth="42" Margin="0,0,3,0" Tag="Left"  Click="ModelOrthoView_Click"/>
                            <Button Content="Right" Padding="6,2" MinWidth="42" Margin="0,0,3,0" Tag="Right" Click="ModelOrthoView_Click"/>
                            <Button Content="Top"   Padding="6,2" MinWidth="42" Margin="0,0,3,0" Tag="Top"   Click="ModelOrthoView_Click"/>
                            <Button Content="Bot"   Padding="6,2" MinWidth="42" Margin="0,0,8,0" Tag="Bottom" Click="ModelOrthoView_Click"/>
                            <Button Padding="6,2" Click="ModelResetView_Click"
                                    ToolTip="Restore the default 3/4 orbit angle and reframe on the model.">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource ResetActionIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Reset" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="ModelNoAnimationNote" Orientation="Horizontal" Margin="4,0,4,6"
                                    Visibility="Collapsed" Opacity="0.85">
                            <Image Source="{StaticResource TriangleAlertIcon}" Width="14" Height="14"
                                   VerticalAlignment="Top" Margin="0,2,6,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFE0A030"
                                       Text="No animation found next to this model -- pick one from the Animation dropdown, or check 'Include whole install' to search further. Showing unposed rest data, which may look distorted."/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
