<Application x:Class="TLJExplorer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TLJExplorer"
             xmlns:services="clr-namespace:TLJExplorer.Services"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Icons/VectorIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <services:ResourceKeyToImageConverter x:Key="ResourceKeyToImageConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
