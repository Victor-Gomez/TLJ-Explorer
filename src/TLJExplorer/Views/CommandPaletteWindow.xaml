<Window x:Class="TLJExplorer.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Go to File" Height="420" Width="640"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">
    <DockPanel Margin="12">
        <TextBox x:Name="QueryBox" DockPanel.Dock="Top" FontSize="16" Padding="6,4" Margin="0,0,0,8"
                 TextChanged="QueryBox_TextChanged" PreviewKeyDown="QueryBox_PreviewKeyDown"/>
        <TextBlock x:Name="HintText" DockPanel.Dock="Bottom" Margin="0,8,0,0" Opacity="0.6" FontSize="11"
                   Text="Type to fuzzy-match a path. Enter opens, Esc cancels, ↑/↓ moves selection."/>
        <ListBox x:Name="ResultsList" MouseDoubleClick="ResultsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.65" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
