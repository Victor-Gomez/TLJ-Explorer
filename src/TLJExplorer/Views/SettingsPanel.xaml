<UserControl x:Class="TLJExplorer.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Modal-style overlay: a semi-transparent scrim over the app plus a centered card. The scrim
         is a Border with Background so mouse events don't fall through to controls beneath. -->
    <Border Background="#88000000" MouseLeftButtonDown="Scrim_MouseLeftButtonDown">
        <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Margin="40" MaxWidth="1000" MaxHeight="720"
                MouseLeftButtonDown="Card_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="20,14,12,10">
                    <Button DockPanel.Dock="Right" Padding="10,4" Click="Close_Click"
                            ToolTip="Close settings (Esc)">
                        <TextBlock Text="Close"/>
                    </Button>
                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="CategoryList" Grid.Column="0" BorderThickness="0" Padding="6,6,6,10"
                             SelectionChanged="CategoryList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="14,10"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBoxItem Content="Display" Tag="Display" IsSelected="True"/>
                        <ListBoxItem Content="Assets and Mods" Tag="Mods"/>
                        <ListBoxItem Content="External Tools" Tag="Tools"/>
                        <ListBoxItem Content="Diagnostics" Tag="Diagnostics"/>
                        <ListBoxItem Content="Appearance" Tag="Appearance"/>
                    </ListBox>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="32,16,32,24">

                            <!-- Display -->
                            <StackPanel x:Name="DisplaySection">
                                <TextBlock Text="Display" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Rendering options for images, textures, and 3D previews."
                                           Opacity="0.7" Margin="0,0,0,22"/>

                                <TextBlock Text="Textures" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ShowMipMapsCheck" Content="Show mip maps"
                                          Checked="ShowMipMaps_Changed" Unchecked="ShowMipMaps_Changed"/>
                                <TextBlock Text="Include mip-map levels in TM texture previews."
                                           Opacity="0.6" FontSize="11" Margin="22,2,0,14"/>

                                <CheckBox x:Name="HighQualityCheck" Content="High quality rendering"
                                          Checked="HighQuality_Changed" Unchecked="HighQuality_Changed"/>
                                <TextBlock Text="Prefer slower, higher-quality rendering for previews."
                                           Opacity="0.6" FontSize="11" Margin="22,2,0,20"/>

                                <TextBlock Text="Anti-aliasing" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Sample count for the 3D model viewer."
                                           Opacity="0.6" FontSize="11" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="AaDefaultRadio" GroupName="Aa" Content="Default" Margin="0,0,16,0" Tag="-1" Checked="Aa_Changed"/>
                                    <RadioButton x:Name="AaNoneRadio"    GroupName="Aa" Content="None"    Margin="0,0,16,0" Tag="0"  Checked="Aa_Changed"/>
                                    <RadioButton x:Name="Aa2xRadio"      GroupName="Aa" Content="2x"      Margin="0,0,16,0" Tag="2"  Checked="Aa_Changed"/>
                                    <RadioButton x:Name="Aa4xRadio"      GroupName="Aa" Content="4x"      Tag="4" Checked="Aa_Changed"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Assets and Mods -->
                            <StackPanel x:Name="ModsSection" Visibility="Collapsed">
                                <TextBlock Text="Assets and Mods" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="How the file tree and previews resolve overrides."
                                           Opacity="0.7" Margin="0,0,0,22"/>

                                <CheckBox x:Name="HideLocalizedCheck" Content="Hide localized entries"
                                          Checked="HideLocalized_Changed" Unchecked="HideLocalized_Changed"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11" Margin="22,2,0,14"
                                           Text="Hide XARC entries flagged as localised (non-English). Only the English (flag=0) variants remain visible in the tree."/>

                                <CheckBox x:Name="LoadAssetModsCheck" Content="Load asset mods"
                                          Checked="LoadAssetMods_Changed" Unchecked="LoadAssetMods_Changed"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11" Margin="22,2,0,22"
                                           Text="Serve loose files under &lt;archive dir&gt;\xarc\ as overrides for the matching archive entries (ScummVM Stark's mod convention)."/>

                                <TextBlock Text="External mods folder" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11" Margin="0,0,0,8"
                                           Text="A folder outside the install that mirrors its layout — files under &lt;modsDir&gt;/&lt;relPath&gt;/xarc/&lt;name&gt; override the matching archive entries."/>
                                <DockPanel Margin="0,0,0,10">
                                    <Button x:Name="ClearExternalModsButton" DockPanel.Dock="Right"
                                            Content="Clear" Padding="12,4" Margin="6,0,0,0" Click="ClearExternalMods_Click"/>
                                    <Button DockPanel.Dock="Right" Content="Browse..." Padding="12,4" Click="SelectExternalMods_Click"/>
                                    <Border BorderBrush="{DynamicResource TextFillColorSecondaryBrush}" BorderThickness="0,0,0,1"
                                            Padding="4,3,10,3">
                                        <TextBlock x:Name="ExternalModsPathText" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Opacity="0.85"/>
                                    </Border>
                                </DockPanel>
                                <Button HorizontalAlignment="Left" Content="Diagnose external mods..."
                                        Padding="12,4" Click="DiagnoseExternalMods_Click"/>
                            </StackPanel>

                            <!-- External Tools -->
                            <StackPanel x:Name="ToolsSection" Visibility="Collapsed">
                                <TextBlock Text="External Tools" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Paths to executables the app shells out to."
                                           Opacity="0.7" Margin="0,0,0,22"/>

                                <TextBlock Text="ffmpeg.exe" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11" Margin="0,0,0,8"
                                           Text="Required to transcode Bink (.bbb) and Smacker (.sss) videos for playback. Point at ffmpeg.exe from a &quot;shared&quot; build (gyan.dev or BtbN)."/>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Locate..." Padding="12,4" Margin="6,0,0,0" Click="LocateFfmpeg_Click"/>
                                    <Border BorderBrush="{DynamicResource TextFillColorSecondaryBrush}" BorderThickness="0,0,0,1"
                                            Padding="4,3,10,3">
                                        <TextBlock x:Name="FfmpegPathText" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Opacity="0.85"/>
                                    </Border>
                                </DockPanel>
                            </StackPanel>

                            <!-- Diagnostics -->
                            <StackPanel x:Name="DiagnosticsSection" Visibility="Collapsed">
                                <TextBlock Text="Diagnostics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Troubleshooting output useful when reporting an issue."
                                           Opacity="0.7" Margin="0,0,0,22"/>

                                <CheckBox x:Name="DumpSceneDiagnosticsCheck" Content="Dump scene diagnostics"
                                          Checked="DumpSceneDiagnostics_Changed" Unchecked="DumpSceneDiagnostics_Changed"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11" Margin="22,2,0,0"
                                           Text="When a scene folder is opened, also write a per-scene table to %TEMP%\TLJExplorer_last_scene_items.txt."/>
                            </StackPanel>

                            <!-- Appearance -->
                            <StackPanel x:Name="AppearanceSection" Visibility="Collapsed">
                                <TextBlock Text="Appearance" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Light or dark mode for the application chrome."
                                           Opacity="0.7" Margin="0,0,0,22"/>

                                <TextBlock Text="Theme" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel>
                                    <RadioButton x:Name="ThemeSystemRadio" GroupName="Theme" Content="Follow system" Margin="0,0,0,8" Tag="System" Checked="Theme_Changed"/>
                                    <RadioButton x:Name="ThemeLightRadio" GroupName="Theme" Content="Light"          Margin="0,0,0,8" Tag="Light"  Checked="Theme_Changed"/>
                                    <RadioButton x:Name="ThemeDarkRadio"  GroupName="Theme" Content="Dark"           Tag="Dark"   Checked="Theme_Changed"/>
                                </StackPanel>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Border>
</UserControl>
