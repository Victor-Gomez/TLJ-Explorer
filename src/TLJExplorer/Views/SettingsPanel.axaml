<UserControl x:Class="TLJExplorer.Views.SettingsPanel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Styles>
        <!-- WinUI-style settings row: a rounded rectangle with title+subtitle on the left and a
             control docked to the right. Rows stack vertically with a small gap. -->
        <Style Selector="Border.settingCard">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBlock.settingTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.settingSubtitle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style Selector="TextBlock.sectionHeader">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="Margin" Value="2,18,0,6"/>
        </Style>

        <!-- WinUI 3 NavigationViewItem look for the category list: rounded pill background on
             hover/select, plus a short vertical accent bar on the left of the selected item. -->
        <Style Selector="ListBoxItem.settingsNav">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <Border Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4"/>
                        <Rectangle Name="Indicator" Width="3" Height="16"
                                   RadiusX="1.5" RadiusY="1.5"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Margin="2,0,0,0"
                                   Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                   Opacity="0"/>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ListBoxItem.settingsNav:pointerover /template/ Border#Bg">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
        </Style>
        <Style Selector="ListBoxItem.settingsNav:selected /template/ Border#Bg">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
        </Style>
        <Style Selector="ListBoxItem.settingsNav:selected /template/ Rectangle#Indicator">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </UserControl.Styles>

    <!-- Modal-style overlay: a semi-transparent scrim over the app plus a centered card. The scrim
         is a Border with Background so pointer events don't fall through to controls beneath. -->
    <Border Background="#88000000" PointerPressed="Scrim_PointerPressed">
        <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Margin="40" MaxWidth="1000" MaxHeight="720"
                PointerPressed="Card_PointerPressed">
            <Grid RowDefinitions="Auto,*">
                <DockPanel Grid.Row="0" Margin="20,10,10,8">
                    <Button DockPanel.Dock="Right" Width="34" Height="34" Padding="0" Click="Close_Click"
                            Background="Transparent" BorderThickness="0"
                            ToolTip.Tip="Close settings (Esc)">
                        <Image Source="{StaticResource CloseIcon}" Width="12" Height="12"/>
                    </Button>
                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>

                <Grid Grid.Row="1" ColumnDefinitions="220,*">
                    <ListBox x:Name="CategoryList" Grid.Column="0" BorderThickness="0" Padding="4,6,4,10"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="CategoryList_SelectionChanged">
                        <ListBoxItem Classes="settingsNav" Content="Display" Tag="Display" IsSelected="True"/>
                        <ListBoxItem Classes="settingsNav" Content="Assets and Mods" Tag="Mods"/>
                        <ListBoxItem Classes="settingsNav" Content="External Tools" Tag="Tools"/>
                        <ListBoxItem Classes="settingsNav" Content="Diagnostics" Tag="Diagnostics"/>
                        <ListBoxItem Classes="settingsNav" Content="Appearance" Tag="Appearance"/>
                    </ListBox>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="32,16,32,24">

                            <!-- Display -->
                            <StackPanel x:Name="DisplaySection">
                                <TextBlock Text="Display" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Rendering options for images, textures, and 3D previews."
                                           Opacity="0.7" Margin="0,0,0,16"/>

                                <TextBlock Text="Textures" Classes="sectionHeader" Margin="2,0,0,6"/>
                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <CheckBox x:Name="ShowMipMapsCheck" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                                                  Checked="ShowMipMaps_Changed" Unchecked="ShowMipMaps_Changed"/>
                                        <StackPanel>
                                            <TextBlock Text="Show mip maps" Classes="settingTitle"/>
                                            <TextBlock Text="Include mip-map levels in TM texture previews." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <CheckBox x:Name="HighQualityCheck" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                                                  Checked="HighQuality_Changed" Unchecked="HighQuality_Changed"/>
                                        <StackPanel>
                                            <TextBlock Text="High quality rendering" Classes="settingTitle"/>
                                            <TextBlock Text="Prefer slower, higher-quality rendering for previews." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="3D viewer" Classes="sectionHeader"/>
                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <ComboBox x:Name="AaCombo" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="140"
                                                  SelectionChanged="Aa_SelectionChanged">
                                            <ComboBoxItem Content="Default" Tag="-1"/>
                                            <ComboBoxItem Content="None"    Tag="0"/>
                                            <ComboBoxItem Content="2x"      Tag="2"/>
                                            <ComboBoxItem Content="4x"      Tag="4"/>
                                        </ComboBox>
                                        <StackPanel>
                                            <TextBlock Text="Anti-aliasing" Classes="settingTitle"/>
                                            <TextBlock Text="Sample count for the 3D model viewer." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </StackPanel>

                            <!-- Assets and Mods -->
                            <StackPanel x:Name="ModsSection" IsVisible="False">
                                <TextBlock Text="Assets and Mods" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="How the file tree and previews resolve overrides."
                                           Opacity="0.7" Margin="0,0,0,16"/>

                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <CheckBox x:Name="HideLocalizedCheck" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                                                  Checked="HideLocalized_Changed" Unchecked="HideLocalized_Changed"/>
                                        <StackPanel>
                                            <TextBlock Text="Hide localized entries" Classes="settingTitle"/>
                                            <TextBlock Text="Hide XARC entries flagged as localised (non-English). Only the English (flag=0) variants remain visible in the tree." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <CheckBox x:Name="LoadAssetModsCheck" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                                                  Checked="LoadAssetMods_Changed" Unchecked="LoadAssetMods_Changed"/>
                                        <StackPanel>
                                            <TextBlock Text="Load asset mods" Classes="settingTitle"/>
                                            <TextBlock Text="Serve loose files under &lt;archive dir&gt;\xarc\ as overrides for the matching archive entries (ScummVM Stark's mod convention)." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="External mods folder" Classes="sectionHeader"/>
                                <Border Classes="settingCard">
                                    <StackPanel>
                                        <TextBlock Text="A folder outside the install that mirrors its layout -- files under &lt;modsDir&gt;/&lt;relPath&gt;/xarc/&lt;name&gt; override the matching archive entries." Classes="settingSubtitle" Margin="0,0,0,10"/>
                                        <DockPanel>
                                            <Button x:Name="ClearExternalModsButton" DockPanel.Dock="Right"
                                                    Content="Clear" Padding="12,4" Margin="6,0,0,0" Click="ClearExternalMods_Click"/>
                                            <Button DockPanel.Dock="Right" Content="Browse..." Padding="12,4" Margin="6,0,0,0" Click="SelectExternalMods_Click"/>
                                            <TextBox x:Name="ExternalModsPathBox" VerticalAlignment="Center" Padding="6,4"
                                                     LostFocus="ExternalModsPathBox_LostFocus"
                                                     KeyDown="ExternalModsPathBox_KeyDown"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Run" Padding="16,4" Margin="12,0,0,0" Click="DiagnoseExternalMods_Click"/>
                                        <StackPanel>
                                            <TextBlock Text="Diagnose external mods" Classes="settingTitle"/>
                                            <TextBlock Text="Walk the current external mods folder and report which files did and did not resolve to VFS entries." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </StackPanel>

                            <!-- External Tools -->
                            <StackPanel x:Name="ToolsSection" IsVisible="False">
                                <TextBlock Text="External Tools" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Paths to executables the app shells out to."
                                           Opacity="0.7" Margin="0,0,0,16"/>

                                <Border Classes="settingCard">
                                    <StackPanel>
                                        <TextBlock Text="ffmpeg" Classes="settingTitle"/>
                                        <TextBlock Text="Required to transcode Bink (.bbb) and Smacker (.sss) videos for playback. Point at an ffmpeg build from a &quot;shared&quot; build (gyan.dev or BtbN) on Windows, or your distro's ffmpeg package on Linux." Classes="settingSubtitle" Margin="0,2,0,10"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Locate..." Padding="12,4" Margin="6,0,0,0" Click="LocateFfmpeg_Click"/>
                                            <TextBox x:Name="FfmpegPathBox" VerticalAlignment="Center" Padding="6,4"
                                                     LostFocus="FfmpegPathBox_LostFocus"
                                                     KeyDown="FfmpegPathBox_KeyDown"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Diagnostics -->
                            <StackPanel x:Name="DiagnosticsSection" IsVisible="False">
                                <TextBlock Text="Diagnostics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Troubleshooting output useful when reporting an issue."
                                           Opacity="0.7" Margin="0,0,0,16"/>

                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <CheckBox x:Name="DumpSceneDiagnosticsCheck" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                                                  Checked="DumpSceneDiagnostics_Changed" Unchecked="DumpSceneDiagnostics_Changed"/>
                                        <StackPanel>
                                            <TextBlock Text="Dump scene diagnostics" Classes="settingTitle"/>
                                            <TextBlock Text="When a scene folder is opened, also write a per-scene table to the temp folder's TLJExplorer_last_scene_items.txt." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </StackPanel>

                            <!-- Appearance -->
                            <StackPanel x:Name="AppearanceSection" IsVisible="False">
                                <TextBlock Text="Appearance" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Light or dark mode for the application chrome."
                                           Opacity="0.7" Margin="0,0,0,16"/>

                                <Border Classes="settingCard">
                                    <DockPanel>
                                        <ComboBox x:Name="ThemeCombo" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="140"
                                                  SelectionChanged="Theme_SelectionChanged">
                                            <ComboBoxItem Content="Follow system" Tag="System"/>
                                            <ComboBoxItem Content="Light"         Tag="Light"/>
                                            <ComboBoxItem Content="Dark"          Tag="Dark"/>
                                        </ComboBox>
                                        <StackPanel>
                                            <TextBlock Text="Choose your mode" Classes="settingTitle"/>
                                            <TextBlock Text="Change the colors that appear in the app." Classes="settingSubtitle"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Border>
</UserControl>
